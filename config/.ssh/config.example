# ~/.ssh/config
# SSH client configuration

# ─────────────────────────────────────────────
# Global defaults
# ─────────────────────────────────────────────
Host *
    ServerAliveInterval 60
    ServerAliveCountMax 3
    AddKeysToAgent yes
    UseKeychain yes
    IdentitiesOnly yes

# ─────────────────────────────────────────────
# GitHub
# ─────────────────────────────────────────────
Host github.com
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519

# ─────────────────────────────────────────────
# Local network hosts
# ─────────────────────────────────────────────

# Friendly alias for 192.168.10.50 — rename/fill in as appropriate
Host server-50
    HostName 192.168.10.50
    User john
    IdentityFile ~/.ssh/id_ed25519
    Port 22

# Friendly alias for 192.168.10.105 — rename/fill in as appropriate
Host server-105
    HostName 192.168.10.105
    User john
    IdentityFile ~/.ssh/id_ed25519
    Port 22

# Local mDNS host
Host monitor.local
    HostName monitor.local
    User john
    IdentityFile ~/.ssh/id_ed25519
    Port 22

# ─────────────────────────────────────────────
# Tunnel / jump host template (uncomment to use)
# ─────────────────────────────────────────────
# Host remote-via-jump
#     HostName 10.0.0.10
#     User john
#     IdentityFile ~/.ssh/id_ed25519
#     ProxyJump jump-host

# Host jump-host
#     HostName your.jump.host.com
#     User john
#     IdentityFile ~/.ssh/id_ed25519
